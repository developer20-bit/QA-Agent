{
  "name": "qa-agent",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "CLI: site health (crawl, internal links, HTML reports, optional local live dashboard). Legacy: form smoke tests.",
  "bin": {
    "qa-agent": "./dist/index.js"
  },
  "scripts": {
    "start": "bash scripts/start.sh",
    "build": "tsc",
    "build:web": "npm run build --prefix web",
    "build:all": "npm run build && npm run build:web",
    "health": "node dist/index.js health",
    "run": "node dist/index.js run",
    "dev": "tsx src/index.ts health",
    "dev:run": "tsx src/index.ts run",
    "lint": "tsc --noEmit",
    "fixture": "npm start --prefix fixture-site",
    "fixture:kill": "node scripts/kill-port.mjs 3333",
    "setup-browsers": "playwright install chromium"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "cheerio": "^1.2.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "formidable": "^3.5.4",
    "nodemailer": "^6.10.0",
    "p-limit": "^6.2.0",
    "pdf-parse": "^2.4.5",
    "playwright": "^1.51.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/formidable": "^3.5.0",
    "@types/node": "^22.13.10",
    "@types/nodemailer": "^6.4.17",
    "@types/pdf-parse": "^1.1.5",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
